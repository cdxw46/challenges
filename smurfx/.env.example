# Entorno (development, production, test)
NODE_ENV=development

# Base de Datos (PostgreSQL)
DATABASE_URL="postgresql://smurfx_user:smurfx_password@localhost:5432/smurfx?schema=public"

# Caché (Redis)
REDIS_URL="redis://localhost:6379"

# Servidor Backend
PORT=4000
API_PREFIX=/api/v1

# Autenticación JWT
JWT_SECRET="super_secret_jwt_key_change_in_production"
JWT_EXPIRES_IN="7d"

# Frontend URLs
FRONTEND_URL="http://localhost:3000"
ADMIN_URL="http://localhost:3001"

# Integración Pagos (Stripe)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PUBLIC_KEY="pk_test_..."

# Integración Pagos (PayPal)
PAYPAL_CLIENT_ID="your_paypal_client_id"
PAYPAL_CLIENT_SECRET="your_paypal_client_secret"

# Integración Pagos (Klarna - vía Stripe o Directa)
KLARNA_API_KEY="your_klarna_api_key"

# Integración Emails (SMTP - SendGrid, AWS SES, Resend, etc.)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="your_smtp_user"
SMTP_PASS="your_smtp_password"
EMAIL_FROM="no-reply@smurfx.com"

# Almacenamiento S3 (AWS, Cloudinary, etc.) para imágenes
AWS_ACCESS_KEY_ID="your_aws_key"
AWS_SECRET_ACCESS_KEY="your_aws_secret"
AWS_REGION="eu-west-1"
AWS_S3_BUCKET="smurfx-assets"

# Google OAuth
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# Analíticas
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_FB_PIXEL_ID="XXXXXXXXXXXXXXX"
