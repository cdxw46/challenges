# --- Database ---
# SQLite for development; switch to "postgresql://user:pass@host:5432/smurfx" in production
DATABASE_URL="file:./dev.db"

# --- Auth ---
JWT_SECRET="change-me-to-a-long-random-string"
JWT_REFRESH_SECRET="change-me-to-another-long-random-string"

# --- Site ---
NEXT_PUBLIC_SITE_URL="https://smurfx.example"
NEXT_PUBLIC_SITE_NAME="SMURFX"

# --- Stripe ---
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- Optional providers ---
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
KLARNA_USERNAME=""
KLARNA_PASSWORD=""
BIZUM_MERCHANT=""

# --- SMTP ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="SMURFX <hello@smurfx.com>"

# --- Admin seed (used by `npm run seed`) ---
ADMIN_EMAIL="admin@smurfx.com"
ADMIN_PASSWORD="Admin1234!"

# --- Analytics ---
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_FB_PIXEL_ID=""
